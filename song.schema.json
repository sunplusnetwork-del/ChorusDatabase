{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schema/song.schema.json",
  "title": "ChoralSong",
  "description": "日本の合唱曲データベース 1曲分のレコード定義。クローラーが自動生成するレコードも、コミュニティがPRで追加するレコードも、このスキーマに従う。",
  "type": "object",
  "required": ["id", "title", "composer", "source_type", "sources", "created_at", "updated_at"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{3,80}$",
      "description": "一意なID。コンクール課題曲は 'jca-{年度}-{曲記号}' (例: jca-2025-G1)、それ以外は 'auto-{ハッシュ}' または投稿者が自由に決めたスラッグ。"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "曲名"
    },
    "title_yomi": {
      "type": ["string", "null"],
      "description": "曲名のよみがな（任意）"
    },
    "composer": {
      "type": ["string", "null"],
      "description": "作曲者名。原則1名だが、表記上複数名が連名の場合は文字列のまま保持する。"
    },
    "lyricist": {
      "type": ["string", "null"],
      "description": "作詞者名。詩がない（既存の詩への作曲、ラテン語典礼文など）場合は null。"
    },
    "original_author": {
      "type": ["string", "null"],
      "description": "原詩の作者（外国語詩を日本語訳・翻案した場合の原作者名）"
    },
    "arranger": {
      "type": ["string", "null"],
      "description": "編曲者名（is_arrangement が true の場合に設定）"
    },
    "is_arrangement": {
      "type": "boolean",
      "default": false,
      "description": "既存曲（民謡・聖歌など）の編曲かどうか"
    },
    "collection": {
      "type": ["string", "null"],
      "description": "収録されている組曲・曲集名（例:「光る砂漠」）"
    },
    "voicing_category": {
      "type": ["string", "null"],
      "enum": ["混声", "男声", "女声", "同声", "児童", "同声・児童", null],
      "description": "声部の大分類"
    },
    "voicing_detail": {
      "type": ["string", "null"],
      "description": "声部の詳細（例: SATB, 混声3部, 無伴奏3部合唱 など）。クローラーは基本的に埋めず null のままにする。"
    },
    "language": {
      "type": ["string", "null"],
      "description": "歌唱言語。可能であれば ISO 639-1（ja, en, de, fr, la, it 等）を推奨するが、判別できない場合は null。"
    },
    "accompaniment": {
      "type": ["string", "null"],
      "enum": ["無伴奏", "ピアノ伴奏", "その他伴奏", null]
    },
    "source_type": {
      "type": "string",
      "enum": ["コンクール課題曲", "演奏会プログラム", "出版譜", "その他"],
      "description": "このレコードの情報源の種類"
    },
    "source_detail": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "contest_year": {"type": ["integer", "null"]},
        "contest_round": {"type": ["integer", "null"]},
        "edition_no": {"type": ["integer", "null"]},
        "piece_code": {"type": ["string", "null"], "description": "例: G1, M3, F2"}
      },
      "description": "source_type が「コンクール課題曲」の場合の詳細情報"
    },
    "publisher": {
      "type": ["string", "null"]
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "notes": {
      "type": ["string", "null"],
      "description": "自由記述の備考"
    },
    "needs_review": {
      "type": "boolean",
      "default": false,
      "description": "true の場合、自動抽出の信頼度が低く人間によるPR修正が望ましいことを示す"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "このレコードの自動抽出に対する信頼度（0〜1）。コミュニティが手動で追加・修正したレコードは 1.0 を推奨。"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["url", "retrieved_at"],
        "additionalProperties": false,
        "properties": {
          "url": {"type": "string", "format": "uri"},
          "retrieved_at": {"type": "string", "format": "date-time"},
          "raw_text": {
            "type": ["string", "null"],
            "description": "クロール元の生テキスト（監査・再パース用）"
          },
          "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1}
        }
      }
    },
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"}
  }
}
